---
/**
 * Astro page — fetches Strava activities at build time via GraphQL.
 *
 * Place in src/pages/strava.astro
 * Set GRAPHQL_ENDPOINT in your .env file.
 */

const ENDPOINT = import.meta.env.GRAPHQL_ENDPOINT || 'https://yoursite.com/graphql';

const QUERY = `{
  stravaActivities(first: 10) {
    title
    distance
    duration
    date
    type
    unit
    speedUnit
    svgMap
    stravaUrl
    elevationGain
    averageSpeed
    maxSpeed
    city
    poweredByStrava
  }
}`;

const res = await fetch(ENDPOINT, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ query: QUERY }),
});

const { data } = await res.json();
const activities = data?.stravaActivities ?? [];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Strava Activities</title>
  <style>
    body { max-width: 800px; margin: 0 auto; padding: 2rem; font-family: sans-serif; }
    .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
    .meta { color: #6b7280; font-size: 13px; margin: 0 0 8px; }
    .stats { display: flex; gap: 16px; font-size: 14px; }
    .strava-link { color: #FC5200; font-weight: bold; text-decoration: none; font-size: 13px; margin-top: 8px; display: inline-block; }
    .attribution { font-size: 12px; color: #9ca3af; text-align: center; }
  </style>
</head>
<body>
  <h1>Strava Activities</h1>

  {activities.map((activity) => (
    <article class="card">
      {activity.svgMap && (
        <div set:html={activity.svgMap} style="margin-bottom: 12px;" />
      )}

      <h2 style="margin: 0 0 4px; font-size: 18px;">{activity.title}</h2>

      <p class="meta">
        {new Date(activity.date).toLocaleDateString('en-US', {
          month: 'long', day: 'numeric', year: 'numeric',
        })}
        {activity.city && ` · ${activity.city}`}
      </p>

      <div class="stats">
        <span><strong>{activity.distance}</strong> {activity.unit}</span>
        <span><strong>{activity.duration}</strong></span>
        <span><strong>{activity.averageSpeed}</strong> {activity.speedUnit}</span>
        <span>{activity.type}</span>
      </div>

      {activity.stravaUrl && (
        <a href={activity.stravaUrl} target="_blank" rel="noopener noreferrer" class="strava-link">
          View on Strava →
        </a>
      )}
    </article>
  ))}

  {activities[0]?.poweredByStrava && (
    <p class="attribution">{activities[0].poweredByStrava}</p>
  )}
</body>
</html>
