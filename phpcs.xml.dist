<?xml version="1.0"?>
<ruleset name="GraphQL Strava Activities">
    <description>WordPress Coding Standards for GraphQL Strava Activities.</description>

    <!-- Scan these files -->
    <file>graphql-strava-activities.php</file>
    <file>includes/</file>

    <!-- Exclude stubs and tests from scanning -->
    <exclude-pattern>stubs/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>

    <!-- Show progress and sniff codes in all reports -->
    <arg value="ps"/>
    <arg name="colors"/>

    <!-- Only fail on errors, not warnings -->
    <config name="severity" value="1"/>
    <arg name="warning-severity" value="0"/>

    <!-- Allow error_log for API error reporting -->
    <rule ref="WordPress.PHP.DevelopmentFunctions.error_log_error_log">
        <severity>0</severity>
    </rule>

    <!-- Allow $default as parameter name -->
    <rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames">
        <severity>0</severity>
    </rule>

    <!-- PHP 8.0+ -->
    <config name="testVersion" value="8.2-"/>

    <!-- WordPress standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- Set minimum WP version -->
    <config name="minimum_wp_version" value="6.0"/>

    <!-- Text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="graphql-strava-activities"/>
            </property>
        </properties>
    </rule>

    <!-- Prefixes -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wpgraphql_strava"/>
                <element value="WPGRAPHQL_STRAVA"/>
            </property>
        </properties>
    </rule>
</ruleset>
